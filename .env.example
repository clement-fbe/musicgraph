# Neo4j connection
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me

# MusicBrainz user agent (required by MusicBrainz API)
MUSICBRAINZ_USER_AGENT=MusicGraph/1.0 (your-email@example.com)

# Spotify Web API (optional — enables artist photos and album covers).
# Create an app at https://developer.spotify.com/dashboard to get these two
# values. A free Spotify account is enough (Premium is NOT required — it is only
# needed to stream audio, not to read catalog metadata / cover art).
# Leave empty to run without covers; the app degrades gracefully.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
